# SentinelX Docker — configuración
# Copiar a .env y completar los valores
#
#   cp .env.example .env
#   nano .env

# Token interno entre el MCP y el core (generar con: openssl rand -hex 32)
SENTINEL_TOKEN=changeme

# OIDC — completar con los valores de tu proveedor (Keycloak, Auth0, etc.)
OIDC_ISSUER=https://auth.example.com/realms/sentinelx
OIDC_JWKS_URI=https://auth.example.com/realms/sentinelx/protocol/openid-connect/certs
OIDC_EXPECTED_AUDIENCE=
RESOURCE_URL=https://sentinelx.example.com

# Activar logs de autenticación (útil para debugging inicial)
AUTH_DEBUG=false
