# SentinelX Docker — .env.example
# Copy to .env and fill in your values:
#   cp .env.example .env && nano .env
#
# Tip: run install.sh to generate .env automatically.

# ── Core agent ───────────────────────────────────────────────────────────────
# Internal token between the MCP server and the core agent.
# Generate a secure value with: openssl rand -hex 32
SENTINEL_TOKEN=changeme

# Execution mode: where commands run.
#   host      — on the real host via nsenter (requires pid=host + privileged=true)
#   container — inside the container only (isolated, no special privileges)
SENTINEL_EXEC_MODE=host

# ── Endpoint ─────────────────────────────────────────────────────────────────
# Public domain of the MCP endpoint.
# This is the URL you'll add to Claude or ChatGPT.
MCP_DOMAIN=sentinelx.yourdomain.com
RESOURCE_URL=https://sentinelx.yourdomain.com

# ── Authentication (simple mode) ─────────────────────────────────────────────
# In simple mode, OIDC is disabled. The MCP accepts any request that carries
# the correct SENTINEL_TOKEN. Good for personal use.
#
# Leave OIDC_ISSUER and OIDC_JWKS_URI empty to enable simple mode.
OIDC_ISSUER=
OIDC_JWKS_URI=
OIDC_EXPECTED_AUDIENCE=
AUTH_DEBUG=false

# ── Authentication (oidc mode) — fill in if AUTH_MODE=oidc ──────────────────
# These are set automatically by install.sh + zitadel-setup.py.
# If you're setting up manually, fill in your OIDC provider values.
#
# AUTH_MODE=oidc
# AUTH_DOMAIN=auth-sentinelx.yourdomain.com
# OIDC_ISSUER=https://auth-sentinelx.yourdomain.com
# OIDC_JWKS_URI=https://auth-sentinelx.yourdomain.com/oauth/v2/keys
# OIDC_EXPECTED_AUDIENCE=<client-id-from-zitadel>

# ── Zitadel (oidc mode only) ─────────────────────────────────────────────────
# These are generated automatically by install.sh.
# Required when using docker-compose.oidc.yml.
#
# ZITADEL_MASTERKEY=<exactly-32-characters>
# ZITADEL_DB_USER_PASS=<random-password>
# ZITADEL_ADMIN_PASS=<admin-password>
